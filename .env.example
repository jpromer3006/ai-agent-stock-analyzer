# Ai-Agent Stock Analyzer — Environment Variables
# Copy to .env and fill in values.
#
# ANTHROPIC_API_KEY is read from Mac Keychain first, .env as fallback.
#   security add-generic-password -a "$USER" -s "ANTHROPIC_API_KEY" -w "sk-ant-..."

ANTHROPIC_API_KEY=
FRED_API_KEY=
ALPHA_VANTAGE_API_KEY=
FMP_API_KEY=

# Optional
ELEVENLABS_API_KEY=
GEE_SERVICE_ACCOUNT_KEY_PATH=
